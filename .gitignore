# ── Scan output (client data — never commit) ──────────────────────────────────
recon/
findings/
reports/
targets/

# ── Client-specific remediation packs (instances of templates/remediation_pack/) ─
# Generic templates live in templates/remediation_pack/ (committed).
# Per-engagement instances under client_remediation_pack/<engagement>/ contain
# target hostnames, AWS account/bucket/ALB IDs, IPs, usernames, PoC artifact IDs.
client_remediation_pack/

